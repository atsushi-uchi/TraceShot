<Window x:Class="TraceShot.Features.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="設定 - TraceShot" Height="650" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="保存設定" Margin="0,0,0,15" Padding="10">
            <StackPanel>
                <TextBlock Text="デフォルト保存フォルダ:"/>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SaveFolderTextBox" IsReadOnly="True" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="参照..." Click="BrowseFolder_Click" Width="60" Margin="5,0,0,0"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="録画・エンコード設定" Grid.Row="1" Padding="10">
            <StackPanel>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="フレームレート:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="FpsComboBox" Grid.Column="1">
                        <ComboBoxItem Content="15 fps (軽量)" Tag="15"/>
                        <ComboBoxItem Content="30 fps (標準)" Tag="30"/>
                        <ComboBoxItem Content="60 fps (滑らか)" Tag="60"/>
                    </ComboBox>
                </Grid>
                <CheckBox x:Name="HardwareAccelCheckBox" Content="ハードウェアアクセラレーションを使用する" Margin="0,10,0,0" IsChecked="True"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="操作設定" Grid.Row="2" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="証跡追加ホットキー:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <Button x:Name="HotkeySettingButton" Grid.Column="1" Content="F12" Margin="0,0,0,5" Click="HotkeySettingButton_Click"/>
                <TextBlock Grid.Column="2" Text="※クリックしてキー入力" VerticalAlignment="Center" Margin="10,0,0,5" FontSize="10" Foreground="Gray"/>

                <TextBlock Grid.Row="1" Text="音声メモホットキー:" VerticalAlignment="Center" Margin="0,5,10,0"/>
                <Button x:Name="VoiceHotkeySettingButton" Grid.Row="1" Grid.Column="1" Content="None" Margin="0,5,0,0" Click="HotkeySettingButton_Click"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="※クリックしてキー入力" VerticalAlignment="Center" Margin="10,5,0,0" FontSize="10" Foreground="Gray"/>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="EnableVoiceRecognitionCheckBox" Content="音声認識を有効にする" VerticalAlignment="Center"/>
                    <TextBlock Text="（起動時の負荷を軽減するにはオフにしてください）" 
                       VerticalAlignment="Center" FontSize="10" Foreground="Gray" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        <GroupBox Header="表示色設定" Grid.Row="3" Padding="10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="5,5,5,10">
                    <TextBlock Text="メインカラー (通常時):" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="MainColorPicker" 
                         SelectedColor="{Binding Path=MainColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,5,5,10">
                    <TextBlock Text="ハイライトカラー (ハイライト時):" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="HighlightColorPicker" 
                         SelectedColor="{Binding Path=OverColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="5,5,5,5">
                    <TextBlock Text="バルーン文字色 (通常時):" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="MainTextColorPicker" 
                         SelectedColor="{Binding Path=MainTextColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,5,5,5">
                    <TextBlock Text="バルーン文字色 (ハイライト時):" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="HighlightTextColorPicker" 
                         SelectedColor="{Binding Path=OverTextColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="5,10,5,5">
                    <TextBlock Text="クロップ枠カラー:" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="CropColorPicker" 
                         SelectedColor="{Binding Path=CropColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>

                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,10,5,5">
                    <TextBlock Text="クロップ内塗りつぶし:" FontSize="11" Margin="0,0,0,3"/>
                    <xctk:ColorPicker Name="CropFillColorPicker" 
                         SelectedColor="{Binding Path=CropFillColor, Mode=TwoWay}" 
                         DisplayColorAndName="True"
                         AvailableColorsHeader="おすすめの色"
                         StandardColorsHeader="標準の色"
                         RecentColorsHeader="最近使った色"/>
                </StackPanel>

            </Grid>
        </GroupBox>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="80" IsCancel="True" Margin="5"/>
            <Button Content="保存" Width="80" Click="SaveSettings_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>