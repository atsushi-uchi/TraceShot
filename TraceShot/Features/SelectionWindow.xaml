<Window x:Class="TraceShot.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Coordinates" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        >

    <Grid x:Name="DebugGrid">
        <Border x:Name="InfoPanel" 
                Background="#CC000000" 
                CornerRadius="5" 
                Padding="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TxtScreen" Foreground="Cyan" FontSize="14" FontFamily="Consolas" Text="画面: ---"/>
                <TextBlock x:Name="TxtHandle" Foreground="Yellow" FontSize="14" FontFamily="Consolas" Text="hWnd: ---"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>