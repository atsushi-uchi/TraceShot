<Window x:Class="TraceShot.Features.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
        xmlns:vm="clr-namespace:TraceShot.ViewModels"
        Title="エクスポート設定 - TraceShot" Height="600" Width="1200"
        Background="#F3F3F3" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="NoImagePlaceholder" Color="#1A1A1A" />

        <Style x:Key="MyCustomCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="RootGrid" Background="Transparent">
                            <Border x:Name="Box" 
                                Width="22" Height="22" 
                                CornerRadius="11" 
                                BorderBrush="White" 
                                BorderThickness="2" 
                                Background="#66000000">
                                <Path x:Name="CheckMark" 
                                  Data="M 4,11 L 9,16 L 18,7" 
                                  Stroke="#00FFFF" 
                                  StrokeThickness="3" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round" 
                                  StrokeLineJoin="Round" 
                                  Visibility="Collapsed"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="Background" Value="#AA000000"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#00FFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#00FFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type vm:ExportItemViewModel}">
            <Grid Width="240" Margin="5">
                <Grid>
                    <Image Source="{Binding SnapshotImage, TargetNullValue={StaticResource NoImagePlaceholder}}" 
                   Width="240" Height="135" Stretch="UniformToFill" />

                    <Border Background="#CC000000" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Padding="6,3" 
                    Margin="5" 
                    CornerRadius="4"
                    IsHitTestVisible="False">
                        <TextBlock Text="{Binding SerialNumber, StringFormat='#{0}'}" 
                           Foreground="White" 
                           FontSize="12" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                    </Border>

                    <CheckBox IsChecked="{Binding IsSelected}" Margin="5" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>

                <TextBlock Text="{Binding OriginalBookmark.Time, StringFormat='{}{0:mm\\:ss}'}" 
                   Foreground="White" HorizontalAlignment="Center" Margin="2"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D" Margin="15" CornerRadius="8">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl x:Name="ExportPreviewList" Background="#2D2D2D"
                                  ItemsSource="{Binding ExportItems}"
                                  dd:DragDrop.IsDragSource="True"
                                  dd:DragDrop.IsDropTarget="True"
                                  dd:DragDrop.UseDefaultDragAdorner="True"
                                  dd:DragDrop.DropHandler="{Binding}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ExportItemViewModel}">
                                <Grid Width="240" Margin="8" Background="Transparent">
                                    <StackPanel>
                                        <Grid x:Name="ThumbnailArea" Height="135" MouseLeftButtonDown="Thumbnail_MouseLeftButtonDown">
                                            <Border CornerRadius="6" ClipToBounds="True" Background="#333">
                                                <Image Source="{Binding SnapshotImage, TargetNullValue={StaticResource NoImagePlaceholder}}"  Stretch="UniformToFill">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.4" />
                                                                    <Setter Property="Effect">
                                                                        <Setter.Value>
                                                                            <BlurEffect Radius="2"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Border>

                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" 
                            Margin="6" Padding="6,2" CornerRadius="4" Background="#CC000000">
                                                <TextBlock Text="{Binding SerialNumber, StringFormat='#{0}'}" 
                                   Foreground="#00FFFF" FontSize="11" FontWeight="Bold"/>
                                            </Border>

                                            <Border Background="#CCFF0000" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Padding="5,2" Margin="6" CornerRadius="3"
                            Visibility="{Binding OriginalBookmark.IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="要更新" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>

                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                              Margin="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                              Style="{StaticResource MyCustomCheckBoxStyle}"/>
                                        </Grid>

                                        <TextBlock Text="{Binding Time, StringFormat='{}{0:mm\\:ss}'}" 
                           Foreground="#AAA" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="11"/>

                                        <TextBlock Text="{Binding Note}" Foreground="White" HorizontalAlignment="Center" 
                           FontSize="12" Margin="5,2" MaxHeight="35" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="EmptyGuideText" 
                           Text="右側の「撮影開始」を押すとキャプチャが始まります" 
                           Foreground="#888" 
                           FontSize="18" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>

                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#2D2D2D" Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar x:Name="ExportProgressBar" Width="300" Height="10" Foreground="#4472C4"/>
                        <TextBlock x:Name="StatusText" Text="" Foreground="White" 
                                   FontSize="16" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="PreviewArea" Visibility="Collapsed" Background="#2D2D2D" ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="30,20,30,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#CC000000" CornerRadius="4" Padding="12,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="No." Foreground="#00FFFF" FontSize="16" FontWeight="Bold" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding SelectedPreviewItem.CaseId}" 
                               Foreground="#00FFFF" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text=" - Step " Foreground="#AAA" FontSize="16" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedPreviewItem.StepId}" 
                               Foreground="White" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="15,0,0,0" Padding="20,6" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#CC444444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreviewItem.OriginalBookmark.Result}" Value="OK">
                                                <Setter Property="Background" Value="#CC28A745"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedPreviewItem.OriginalBookmark.Result}" Value="NG">
                                                <Setter Property="Background" Value="#CCDC3545"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedPreviewItem.OriginalBookmark.Result}" Value="PEND">
                                                <Setter Property="Background" Value="Orange"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SelectedPreviewItem.OriginalBookmark.Result}" 
                                    Foreground="White" FontSize="24" FontWeight="Black"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0"  VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="左右キーで移動 / 上下でケース選択 / クリックで一覧に戻る" 
                                   Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,0" FontSize="14"/>
                            <TextBlock Text="{Binding PreviewCounterText}" 
                                   Foreground="White" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="SlideGrid" Grid.Row="1">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="SlideTransform" X="0" Y="0" />
                        </Grid.RenderTransform>
                        <Image x:Name="LargePreviewImage" 
                               Source="{Binding SelectedPreviewItem.SnapshotImage}" 
                               Stretch="Uniform" 
                               Margin="20,10"
                               MouseDown="ClosePreview_Click" />
                    </Grid>

                    <Border Grid.Row="2" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,1,0,0">
                        <TextBlock Text="{Binding SelectedPreviewItem.Note}" 
                                   Foreground="#CCC" 
                                   FontSize="18" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center"
                                   Margin="50,5"
                                   TextWrapping="NoWrap" 
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
                <!--ここまで-->
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,0">
                <TextBlock Text="エクスポート手順" FontSize="18" FontWeight="Bold" Margin="0,15,0,10"/>

                <GroupBox x:Name="CaptureGroupBox" Header="STEP 1: 全ブックマークの撮影" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="解像度" FontSize="12" Foreground="#666"/>
                        <ComboBox x:Name="ExportScaleComboBox" Margin="0,5,0,10" SelectedIndex="3" Height="30">
                            <ComboBoxItem Content="25% (軽量)" Tag="0.25"/>
                            <ComboBoxItem Content="50% (標準)" Tag="0.5"/>
                            <ComboBoxItem Content="75% (高画質)" Tag="0.75"/>
                            <ComboBoxItem Content="100% (原寸)" Tag="1.0"/>
                        </ComboBox>
                        <Button x:Name="StartCaptureButton" Content="📸 撮影開始 (キャプチャ)" Height="40" Click="StartCapture_Click" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="OutputGroupBox" Header="STEP 2: レポート出力" Padding="10" IsEnabled="False">
                    <StackPanel>
                        <TextBlock Text="保存先フォルダ" FontSize="12" Foreground="#666"/>
                        <DockPanel Margin="0,5,0,15">
                            <Button Content="参照" DockPanel.Dock="Right" Width="50" Click="Browse_Click" Margin="5,0,0,0"/>
                            <TextBox x:Name="OutputPathBox" IsReadOnly="True" Background="#E9E9E9"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="時間表示" Margin="0,0,10,0"/>
                            <RadioButton x:Name="RadioActualTime" Content="実行時間" IsChecked="True"/>
                            <RadioButton x:Name="RadioRelativeTime" Content="経過時間"/>
                        </DockPanel>

                        <CheckBox x:Name="CheckIncludeSummary"
                              Content="サマリー（実施概要）を出力する"
                              IsChecked="True"
                              Margin="0,0,0,15"
                              FontSize="13"
                              FontWeight="SemiBold"
                              Cursor="Hand"/>

                            <TextBlock Text="ドキュメント形式を選択" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                        <Button Content="HTML形式で保存" Height="45" Margin="0,0,0,10" Background="#4472C4" Foreground="White" FontWeight="Bold" Click="ExportHtml_Click"/>
                        <UniformGrid Columns="2" Height="40">
                            <Button Content="PDF出力" Margin="0,0,5,0" Click="ExportPdf_Click"/>
                            <Button Content="Excel出力" Margin="5,0,0,0" Click="ExportExcel_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="※画像をクリックしてドラッグすると並び替えができます" FontSize="11" Foreground="#999" Margin="5,20,5,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>