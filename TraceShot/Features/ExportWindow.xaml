<Window x:Class="TraceShot.Features.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エクスポート設定 - TraceShot" Height="450" Width="800"
        Background="#F3F3F3" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D" Margin="15" CornerRadius="8">
            <Grid>
                <Image x:Name="PreviewImage" Margin="10" Stretch="Uniform">
                    <Image.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.5" Direction="270"/>
                    </Image.Effect>
                </Image>
                <TextBlock Text="PREVIEW" Foreground="#555" FontSize="40" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Margin="10,20,20,20">
            <TextBlock Text="エクスポート設定" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="出力倍率" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ExportScaleComboBox" Margin="0,0,0,15" SelectedIndex="3" Height="30" VerticalContentAlignment="Center">
                <ComboBoxItem Content="25% (軽量)" Tag="0.25"/>
                <ComboBoxItem Content="50% (標準)" Tag="0.5"/>
                <ComboBoxItem Content="75% (高画質)" Tag="0.75"/>
                <ComboBoxItem Content="100% (原寸)" Tag="1.0"/>
            </ComboBox>

            <TextBlock Text="保存先フォルダ" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <DockPanel Margin="0,0,0,25">
                <Button Content="参照" DockPanel.Dock="Right" Width="50" Height="30" Click="Browse_Click" Margin="5,0,0,0"/>
                <TextBox x:Name="OutputPathBox" IsReadOnly="True" Height="30" VerticalContentAlignment="Center" Background="#E9E9E9"/>
            </DockPanel>

            <Separator Margin="0,0,0,20"/>

            <TextBlock Text="ドキュメント生成" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <Button Content="HTML形式で保存" Height="45" Margin="0,0,0,10" Background="#4472C4" Foreground="White" FontWeight="Bold" Click="ExportHtml_Click"/>
            <UniformGrid Columns="2" Height="40">
                <Button Content="PDF出力" Margin="0,0,5,0" Click="ExportPdf_Click"/>
                <Button Content="Excel出力" Margin="5,0,0,0" Click="ExportExcel_Click"/>
            </UniformGrid>
        </StackPanel>
        <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#AA000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar x:Name="ExportProgressBar" Width="300" Height="20" IsIndeterminate="False" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusText" Text="エクスポート中... (0/0)" Foreground="White" 
                   FontSize="16" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>