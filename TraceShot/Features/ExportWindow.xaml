<Window x:Class="TraceShot.Features.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エクスポート設定 - TraceShot" Height="600" Width="1000"
        Background="#F3F3F3" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D2D" Margin="15" CornerRadius="8">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl x:Name="ExportPreviewList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Background="#3D3D3D" CornerRadius="4" 
                    AllowDrop="True" 
                    MouseMove="Item_MouseMove" 
                    Drop="Item_Drop">
                                    <StackPanel Width="160">
                                        <Grid>
                                            <Image Source="{Binding SnapshotImage}" Width="160" Height="90" Stretch="UniformToFill" IsHitTestVisible="False" />
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                        </Grid>
                                        <TextBlock Text="{Binding OriginalBookmark.Time, StringFormat='{}{0:mm\\:ss}'}" 
                               Foreground="White" HorizontalAlignment="Center" Margin="2"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="EmptyGuideText" Text="右下の「撮影開始」を押すとキャプチャが始まります" 
                           Foreground="#888" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>

                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Background="#CC000000">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar x:Name="ExportProgressBar" Width="300" Height="10" Foreground="#4472C4"/>
                        <TextBlock x:Name="StatusText" Text="キャプチャ中... (0/0)" Foreground="White" 
                                   FontSize="16" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,0">
                <TextBlock Text="エクスポート手順" FontSize="18" FontWeight="Bold" Margin="0,15,0,10"/>

                <GroupBox x:Name="CaptureGroupBox" Header="STEP 1: 全ブックマークの撮影" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="解像度" FontSize="12" Foreground="#666"/>
                        <ComboBox x:Name="ExportScaleComboBox" Margin="0,5,0,10" SelectedIndex="3" Height="30">
                            <ComboBoxItem Content="25% (軽量)" Tag="0.25"/>
                            <ComboBoxItem Content="50% (標準)" Tag="0.5"/>
                            <ComboBoxItem Content="75% (高画質)" Tag="0.75"/>
                            <ComboBoxItem Content="100% (原寸)" Tag="1.0"/>
                        </ComboBox>
                        <Button x:Name="StartCaptureButton" Content="📸 撮影開始 (キャプチャ)" Height="40" Click="StartCapture_Click" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="OutputGroupBox" Header="STEP 2: レポート出力" Padding="10" IsEnabled="False">
                    <StackPanel>
                        <TextBlock Text="保存先フォルダ" FontSize="12" Foreground="#666"/>
                        <DockPanel Margin="0,5,0,15">
                            <Button Content="参照" DockPanel.Dock="Right" Width="50" Click="Browse_Click" Margin="5,0,0,0"/>
                            <TextBox x:Name="OutputPathBox" IsReadOnly="True" Background="#E9E9E9"/>
                        </DockPanel>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="時間表示" Margin="0,0,10,0"/>
                            <RadioButton x:Name="RadioActualTime" Content="実行時間" IsChecked="True"/>
                            <RadioButton x:Name="RadioRelativeTime" Content="経過時間"/>
                        </DockPanel>

                        <TextBlock Text="ドキュメント形式を選択" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                        <Button Content="HTML形式で保存" Height="45" Margin="0,0,0,10" Background="#4472C4" Foreground="White" FontWeight="Bold" Click="ExportHtml_Click"/>
                        <UniformGrid Columns="2" Height="40">
                            <Button Content="PDF出力" Margin="0,0,5,0" Click="ExportPdf_Click"/>
                            <Button Content="Excel出力" Margin="5,0,0,0" Click="ExportExcel_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="※画像をクリックしてドラッグすると並び替えができます" FontSize="11" Foreground="#999" Margin="5,20,5,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>