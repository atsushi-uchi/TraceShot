 <Window x:Class="TraceShot.Features.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:TraceShot"
        xmlns:ctrl="clr-namespace:TraceShot.Controls"
        xmlns:models="clr-namespace:TraceShot.Models"
        xmlns:service="clr-namespace:TraceShot.Services"
        xmlns:conv="clr-namespace:TraceShot.Converters"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="TraceShot" Height="600" Width="900"
        Closed="Window_Closed"
         KeyDown="Window_KeyDown">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarInfo" />
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <VisualBrush x:Key="DiagonalHatchBrush" TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Canvas Width="10" Height="10" Background="#FF888888">
                    <Line X1="0" Y1="0" X2="10" Y2="10" Stroke="Black" StrokeThickness="1"/>
                    <Line X1="10" Y1="00" X2="00" Y2="10" Stroke="Black" StrokeThickness="1"/>
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisConverter" />
        <conv:TypeNameConverter x:Key="TypeNameConverter" />
        <conv:RelativeToAbsoluteConverter x:Key="RelToAbsConverter"/>
        <conv:RectConverter x:Key="RectConverter"/>
        <conv:GroupNameConverter x:Key="GroupNameConverter"/>
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <Style x:Key="StandardToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Rectangle x:Name="Back" RadiusX="10" RadiusY="10" Fill="#999999" Stroke="#BCBCBC" StrokeThickness="1"/>

                            <Ellipse x:Name="Dot" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.2"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Trans" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AnnotationBaseStyle" TargetType="Control">
            <Setter Property="Opacity" Value="0.8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PointResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="handleVisual" 
                             Fill="Transparent"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="handleVisual" Property="Fill" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EdgeResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Rectangle x:Name="handleVisual" 
                               Fill="Transparent" 
                               RadiusX="1" RadiusY="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="handleVisual" Property="Fill" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MoveThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle x:Name="bodyVisual" 
                           Stroke="{Binding DataContext.Config.MainBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                           StrokeThickness="2" 
                           Fill="{TemplateBinding Background}" 
                           Cursor="SizeAll"/>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bodyVisual" Property="Fill" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                <Setter TargetName="bodyVisual" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <!--<Setter TargetName="bodyVisual" Property="Stroke" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />-->
                                <Setter TargetName="bodyVisual" Property="StrokeThickness" Value="3" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsDrawing}" Value="True">
                                <Setter TargetName="bodyVisual" Property="Fill" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                <Setter TargetName="bodyVisual" Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMasking}" Value="True">
                                <Setter TargetName="bodyVisual" Property="Fill" Value="{StaticResource DiagonalHatchBrush}" />
                                <Setter TargetName="bodyVisual" Property="Opacity" Value="0.7" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PointHandleStyle" TargetType="Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="handleVisual" 
                                 Width="6" Height="6" Margin="-3"
                             Fill="{Binding DataContext.Config.MainBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="handleVisual" Property="Fill" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                <Setter TargetName="handleVisual" Property="Width" Value="10" />
                                <Setter TargetName="handleVisual" Property="Height" Value="10" />
                                <Setter TargetName="handleVisual" Property="Margin" Value="-5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CropEdgeResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Rectangle x:Name="handleVisual" 
                               Fill="Transparent" 
                               RadiusX="1" RadiusY="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="handleVisual" Property="Fill" Value="{Binding DataContext.Config.CropBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CropPointResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="handleVisual" 
                             Fill="Transparent"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="handleVisual" Property="Fill" Value="{Binding DataContext.Config.CropBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CropMoveThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle x:Name="bodyVisual" 
                   Stroke="#AAFFFFFF" 
                   StrokeThickness="2" 
                   Fill="{Binding DataContext.Config.CropFillBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                   Cursor="SizeAll"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type ctrl:CropAnnotation}">
            <Canvas x:Name="RootCanvas">
                <Canvas.Width>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                        <Binding Path="RelWidth"/>
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Width>
                <Canvas.Height>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                        <Binding Path="RelHeight"/>
                        <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Height>

                <Path Fill="#A0000000" IsHitTestVisible="False">
                    <Path.Data>
                        <CombinedGeometry GeometryCombineMode="Exclude">
                            <CombinedGeometry.Geometry1>
                                <RectangleGeometry Rect="-3000,-3000,6000,6000"/>
                            </CombinedGeometry.Geometry1>
                            <CombinedGeometry.Geometry2>
                                <RectangleGeometry>
                                    <RectangleGeometry.Rect>
                                        <MultiBinding Converter="{StaticResource RectConverter}">
                                            <Binding Path="ActualWidth" ElementName="RootCanvas"/>
                                            <Binding Path="ActualHeight" ElementName="RootCanvas"/>
                                        </MultiBinding>
                                    </RectangleGeometry.Rect>
                                </RectangleGeometry>
                            </CombinedGeometry.Geometry2>
                        </CombinedGeometry>
                    </Path.Data>
                </Path>

                <Rectangle x:Name="CropBorder"
                     Width="{Binding ActualWidth, ElementName=RootCanvas}" 
                     Height="{Binding ActualHeight, ElementName=RootCanvas}"
                     IsHitTestVisible="False"/>

                <Thumb x:Name="MoveHandle"
                     Style="{StaticResource CropMoveThumbStyle}" DragStarted="OnAnnotation_DragStarted" DragDelta="OnMoveThumb_DragDelta" DragCompleted="OnAnnotation_DragCompleted"
                     Width="{Binding ActualWidth, ElementName=RootCanvas}" 
                     Height="{Binding ActualHeight, ElementName=RootCanvas}"/>

                <Grid x:Name="ResizeHandles" 
                      Width="{Binding ActualWidth, ElementName=RootCanvas}" 
                      Height="{Binding ActualHeight, ElementName=RootCanvas}">

                    <Canvas>
                        <Thumb Canvas.Left="-3" Width="4" Height="{Binding ActualHeight, ElementName=RootCanvas}" 
                               Style="{StaticResource CropEdgeResizeHandleStyle}"
                               Cursor="SizeWE" Tag="Left" DragStarted="OnAnnotation_DragStarted" DragDelta="OnResize_DragDelta" DragCompleted="OnAnnotation_DragCompleted" />
                        <Thumb Canvas.Left="{Binding ActualWidth, ElementName=RootCanvas}" Margin="-3,0,0,0" 
                               Width="4" Height="{Binding ActualHeight, ElementName=RootCanvas}" 
                               Style="{StaticResource CropEdgeResizeHandleStyle}"
                               Cursor="SizeWE" Tag="Right" DragStarted="OnAnnotation_DragStarted" DragDelta="OnResize_DragDelta" DragCompleted="OnAnnotation_DragCompleted"/>
                        <Thumb Canvas.Top="-3" Height="4" Width="{Binding ActualWidth, ElementName=RootCanvas}" 
                               Style="{StaticResource CropEdgeResizeHandleStyle}"
                               Cursor="SizeNS" Tag="Top" DragStarted="OnAnnotation_DragStarted" DragDelta="OnResize_DragDelta" DragCompleted="OnAnnotation_DragCompleted"/>
                        <Thumb Canvas.Top="{Binding ActualHeight, ElementName=RootCanvas}" Margin="0,-3,0,0" 
                               Height="4" Width="{Binding ActualWidth, ElementName=RootCanvas}" 
                               Style="{StaticResource CropEdgeResizeHandleStyle}"
                               Cursor="SizeNS" Tag="Bottom" DragStarted="OnAnnotation_DragStarted" DragDelta="OnResize_DragDelta" DragCompleted="OnAnnotation_DragCompleted" />

                        <Thumb Canvas.Left="0" Canvas.Top="0" Width="8" Height="8" Cursor="SizeNWSE" 
                               Style="{StaticResource CropPointResizeHandleStyle}" 
                               Tag="TopLeft" DragDelta="OnResize_DragDelta"/>
                        <Thumb Canvas.Left="{Binding ActualWidth, ElementName=RootCanvas}" Canvas.Top="0" Margin="-6,0,0,0" 
                               Style="{StaticResource CropPointResizeHandleStyle}" Width="8" Height="8" Cursor="SizeNESW" 
                               Tag="TopRight" DragDelta="OnResize_DragDelta"/>
                        <Thumb Canvas.Left="0" Canvas.Top="{Binding ActualHeight, ElementName=RootCanvas}" Margin="0,-6,0,0" 
                               Style="{StaticResource CropPointResizeHandleStyle}" Width="8" Height="8" Cursor="SizeNESW" 
                               Tag="BottomLeft" DragDelta="OnResize_DragDelta"/>
                        <Thumb Canvas.Left="{Binding ActualWidth, ElementName=RootCanvas}" Canvas.Top="{Binding ActualHeight, ElementName=RootCanvas}" 
                               Style="{StaticResource CropPointResizeHandleStyle}"
                               Margin="-6,-6,0,0" Width="8" Height="8" Cursor="SizeNWSE" 
                               Tag="BottomRight" DragDelta="OnResize_DragDelta"/>
                    </Canvas>
                </Grid>

            </Canvas>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Evidence.CropState, Source={x:Static service:RecService.Instance}}" Value="Confirmed">
                    <Setter TargetName="CropBorder" Property="Stroke" Value="White"/>
                    <Setter TargetName="CropBorder" Property="StrokeThickness" Value="1"/>
                    <Setter TargetName="CropBorder" Property="StrokeDashArray" Value="{x:Null}"/>

                    <Setter TargetName="MoveHandle" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ResizeHandles" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type ctrl:GuardAnnotation}">
            <Grid Background="Transparent" 
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                  IsHitTestVisible="True" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type ctrl:RectAnnotation}">
            <Canvas>
                <Canvas.Left>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}" Mode="TwoWay">
                        <Binding Path="RelX"/>
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Left>
                <Canvas.Top>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}" Mode="TwoWay">
                        <Binding Path="RelY"/>
                        <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Top>
                <Canvas.Width>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}" Mode="TwoWay">
                        <Binding Path="RelWidth"/>
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Width>
                <Canvas.Height>
                    <MultiBinding Converter="{StaticResource RelToAbsConverter}" Mode="TwoWay">
                        <Binding Path="RelHeight"/>
                        <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                    </MultiBinding>
                </Canvas.Height>

                <Thumb Canvas.Left="0" Canvas.Top="0" 
                       Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                       DragStarted="OnAnnotation_DragStarted" DragDelta="OnMoveThumb_DragDelta"
                       DragCompleted="OnAnnotation_DragCompleted">
                    <Thumb.Style>
                        <Style TargetType="Thumb" BasedOn="{StaticResource MoveThumbStyle}">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Style>
                    </Thumb.Style>
                    <Thumb.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="削除" Click="OnDeleteMenu_Click">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="コピー" InputGestureText="Ctrl+C" Click="OnCopyMenu_Click">
                                <MenuItem.Icon>
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="フォーカス設定"
                              IsCheckable="True" 
                              IsChecked="{Binding IsFocused, Mode=OneWay}"
                              Click="OnFocusMenu_Click"/>
                            <MenuItem Header="機密情報黒塗" 
                              IsCheckable="True" 
                              IsChecked="{Binding IsMasking, Mode=OneWay}"
                              Click="OnMaskingMenu_Click"/>
                            <Separator />
                            <MenuItem Header="OCRテキスト読取" Command="{Binding RunOcrCommand}"/>
                        </ContextMenu>
                    </Thumb.ContextMenu>
                </Thumb>

                <Thumb Canvas.Left="0" Canvas.Top="0" 
                       Width="4" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Style="{StaticResource EdgeResizeHandleStyle}"
                       Tag="Left" DragDelta="OnResize_DragDelta" DragStarted="OnAnnotation_DragStarted" 
                       DragCompleted="OnAnnotation_DragCompleted" Cursor="SizeWE"/>
                <Thumb Canvas.Left="0" Canvas.Top="0" 
                       Height="4" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                       Style="{StaticResource EdgeResizeHandleStyle}"
                       Tag="Top" DragDelta="OnResize_DragDelta" DragStarted="OnAnnotation_DragStarted" 
                       DragCompleted="OnAnnotation_DragCompleted" Cursor="SizeNS"/>
                <Thumb Canvas.Left="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" Canvas.Top="0" 
                       Width="4" Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Margin="-3,0,0,0"
                       Style="{StaticResource EdgeResizeHandleStyle}"
                       Tag="Right" DragDelta="OnResize_DragDelta" DragStarted="OnAnnotation_DragStarted" 
                       DragCompleted="OnAnnotation_DragCompleted" Cursor="SizeWE"/>
                <Thumb Canvas.Left="0" Canvas.Top="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Height="4" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Margin="0,-3,0,0"
                       Style="{StaticResource EdgeResizeHandleStyle}"
                       Tag="Bottom" DragDelta="OnResize_DragDelta" DragStarted="OnAnnotation_DragStarted" 
                       DragCompleted="OnAnnotation_DragCompleted" Cursor="SizeNS"/>

                <Thumb Canvas.Left="0" Canvas.Top="0" 
                       Width="12" Height="12" Margin="-4,-4,0,0"
                       Style="{StaticResource PointResizeHandleStyle}"
                       Tag="TopLeft" DragStarted="OnAnnotation_DragStarted" DragDelta="OnResize_DragDelta" 
                       DragCompleted="OnAnnotation_DragCompleted" Cursor="SizeNWSE"/>

                <Thumb Canvas.Left="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Canvas.Top="0" 
                       Width="12" Height="12" Margin="-4,-4,0,0"
                       Style="{StaticResource PointResizeHandleStyle}"
                       DragStarted="OnAnnotation_DragStarted" DragCompleted="OnAnnotation_DragCompleted"
                       Tag="TopRight" DragDelta="OnResize_DragDelta" Cursor="SizeNESW"/>

                <Thumb Canvas.Left="0" 
                       Canvas.Top="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Width="12" Height="12" Margin="-4,-4,0,0"
                       Style="{StaticResource PointResizeHandleStyle}"
                       DragStarted="OnAnnotation_DragStarted" DragCompleted="OnAnnotation_DragCompleted"
                       Tag="BottomLeft" DragDelta="OnResize_DragDelta" Cursor="SizeNESW"/>

                <Thumb Canvas.Left="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Canvas.Top="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" 
                       Width="12" Height="12" Margin="-4,-4,0,0"
                       Style="{StaticResource PointResizeHandleStyle}"
                       DragStarted="OnAnnotation_DragStarted" DragCompleted="OnAnnotation_DragCompleted"
                       Tag="BottomRight" DragDelta="OnResize_DragDelta" Cursor="SizeNWSE"/>
            </Canvas>
        </DataTemplate>

        <DataTemplate DataType="{x:Type ctrl:NoteAnnotation}">
            <Canvas>
                <Line StrokeDashCap="Round">
                    <Line.Style>
                        <Style TargetType="Line">
                            <Setter Property="Stroke" Value="{Binding DataContext.Config.MainBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            <Setter Property="StrokeThickness" Value="2" />

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="StrokeThickness" Value="3" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Line.Style>


                    <Line.X1>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelStartX"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Line.X1>
                    <Line.Y1>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelStartY"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Line.Y1>
                    <Line.X2>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelX"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Line.X2>
                    <Line.Y2>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelY"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Line.Y2>
                </Line>

                <Thumb Style="{StaticResource PointHandleStyle}" 
                       Cursor="SizeAll"
                       Tag="Start" 
                       DragStarted="OnAnnotation_DragStarted" 
                       DragDelta="OnNoteStart_DragDelta"
                       DragCompleted="OnAnnotation_DragCompleted">

                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelStartX"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelStartY"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                        </MultiBinding>
                    </Canvas.Top>
                </Thumb>

                <Canvas>
                    <Canvas.Left>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelX"/>
                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                            <Binding Path="ActualTextWidth"/>
                        </MultiBinding>
                    </Canvas.Left>
                    <Canvas.Top>
                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                            <Binding Path="RelY"/>
                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                            <Binding Path="ActualTextHeight"/>
                        </MultiBinding>
                    </Canvas.Top>
                    <Thumb Tag="End" Cursor="SizeAll"
                           DragDelta="OnNoteText_DragDelta" 
                           DragStarted="OnAnnotation_DragStarted" 
                           DragCompleted="OnAnnotation_DragCompleted">
                        <Thumb.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="削除" Click="OnDeleteMenu_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="コピー" InputGestureText="Ctrl+C" Click="OnCopyMenu_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="編集" Click="OnEditMenu_Click">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Thumb.ContextMenu>

                        <Thumb.Template>
                            <ControlTemplate>
                                <Grid>
                                    <Border Visibility="{Binding IsCommitted, Converter={StaticResource BoolToVisConverter}}"
                                            CornerRadius="5" Padding="5"
                                            SizeChanged="NoteBorder_SizeChanged"
                                            MouseLeftButtonDown="Border_MouseLeftButtonDown"
                                            BorderThickness="2" BorderBrush="Transparent">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{Binding DataContext.Config.MainBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsDragging, RelativeSource={RelativeSource AncestorType=Thumb}}" Value="True">
                                                        <Setter Property="Background" Value="{Binding DataContext.Config.OverBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding Text}" Padding="3" FontSize="14"
                                                   Foreground="{Binding DataContext.Config.MainTextBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </Border>

                                    <!-- TextBox -->
                                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"
                                            IsVisibleChanged="TextBox_IsVisibleChanged"
                                            MinWidth="100"
                                            Panel.ZIndex="1000"
                                            BorderBrush="#FF4A90E2" 
                                            BorderThickness="2"
                                            CornerRadius="5"
                                            Background="#FFFFFFFF">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" 
                                            ShadowDepth="2" 
                                            Opacity="0.35" 
                                            Color="#000000"/>
                                        </Border.Effect>

                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                            PreviewKeyDown="TextInput_PreviewKeyDown"
                                            LostFocus="TextInput_LostFocus"
                                            TextChanged="TextBox_TextChanged"
                                            AcceptsReturn="True" 
                                            TextWrapping="Wrap" 
                                            FontSize="14" 
                                            FontWeight="SemiBold"
                                            BorderThickness="0" 
                                            Background="Transparent" 
                                            Padding="3" 
                                            MinHeight="50"
                                            VerticalContentAlignment="Top"/>
                                    </Border>

                                    <!--<TextBox Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"
                                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="50" AcceptsReturn="True"
                                             IsVisibleChanged="TextBox_IsVisibleChanged"
                                             LostFocus="TextBox_LostFocus"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"/>-->
                                   
                                </Grid>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Canvas>
            </Canvas>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="開く(_O)..." Click="OpenEvidence_Click" InputGestureText="Ctrl+O"/>
                <MenuItem Header="保存(_S)" Click="SaveEvidence_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="エクスポート(_E)..." Click="OpenExport_Click" InputGestureText="Ctrl+E" />
                <Separator />
                <MenuItem Header="終了(_X)" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す" InputGestureText="Ctrl+Z" Click="OnUndo_Click"/>
                <MenuItem Header="やり直す" InputGestureText="Ctrl+Y" Click="OnRedo_Click"/>
                <MenuItem Header="注釈をコピー" InputGestureText="Ctrl+C" Click="OnCopyMenu_Click"/>
                <MenuItem Header="注釈を貼り付け" InputGestureText="Ctrl+V" Click="OnPasteMenu_Click"/>
            </MenuItem>
            <MenuItem Header="設定(_P)" Click="OpenSettings_Click" />
            <!--<MenuItem x:Name="DebugMenuItem" Header="デバッグ ON" IsCheckable="True" Click="DebugButton_Click" />-->
        </Menu>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Black">
                <Grid x:Name="EditModeGrid"
                      Visibility="{Binding CurrentMode,
                                   Converter={StaticResource EnumToVisibilityConverter},
                                   ConverterParameter=Edit}">

                    <MediaElement x:Name="VideoPlayer"
                              Source="{Binding VideoSource}"
                              Stretch="Uniform"
                              LoadedBehavior="Manual" 
                              UnloadedBehavior="Stop" 
                              ScrubbingEnabled="True"
                              MediaOpened="VideoPlayer_MediaOpened"
                              MediaFailed="VideoPlayer_MediaFailed"
                              MediaEnded="VideoPlayer_MediaEnded"/>

                    <ItemsControl ItemsSource="{Binding AnnotationManager.Annotations}"
                          Width="{Binding ActualWidth, ElementName=VideoPlayer}"
                          Height="{Binding ActualHeight, ElementName=VideoPlayer}"
                          Background="Transparent" 
                          ClipToBounds="True"
                          MouseDown="DrawingCanvas_MouseDown" 
                          MouseMove="DrawingCanvas_MouseMove"
                          MouseUp="DrawingCanvas_MouseUp">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas x:Name="AnnotationCanvas" 
                                    Background="Transparent" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}"/>
                                <Setter Property="Canvas.Left">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                                            <Binding Path="RelX"/>
                                            <Binding Path="ActualWidth" ElementName="VideoPlayer"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Canvas.Top">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                                            <Binding Path="RelY"/>
                                            <Binding Path="ActualHeight" ElementName="VideoPlayer"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Converter={StaticResource TypeNameConverter}}" Value="NoteAnnotation">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Converter={StaticResource TypeNameConverter}}" Value="NoteAnnotation">
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>

                <Grid x:Name="RescueModeGrid" 
                              Visibility="{Binding CurrentMode, 
                              Converter={StaticResource EnumToVisibilityConverter}, 
                              ConverterParameter=Rescue}">
                    <Image x:Name="RescueImage" Stretch="Uniform" Source="{Binding RescueImageSource}" />

                    <ItemsControl ItemsSource="{Binding AnnotationManager.Annotations}"
                                  Width="{Binding ActualWidth, ElementName=RescueImage}"
                                  Height="{Binding ActualHeight, ElementName=RescueImage}"
                                  Background="Transparent" 
                                  ClipToBounds="True"
                                  MouseDown="DrawingCanvas_MouseDown" 
                                  MouseMove="DrawingCanvas_MouseMove"
                                  MouseUp="DrawingCanvas_MouseUp">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas x:Name="AnnotationCanvas" 
                                    Background="Transparent" IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}"/>
                                <Setter Property="Canvas.Left">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                                            <Binding Path="RelX"/>
                                            <Binding Path="ActualWidth" ElementName="RescueImage"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Canvas.Top">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource RelToAbsConverter}">
                                            <Binding Path="RelY"/>
                                            <Binding Path="ActualHeight" ElementName="RescueImage"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Converter={StaticResource TypeNameConverter}}" Value="NoteAnnotation">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Converter={StaticResource TypeNameConverter}}" Value="NoteAnnotation">
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Grid>

                <Grid x:Name="RecordingModeGrid"
                             Visibility="{Binding CurrentMode,
                             Converter={StaticResource EnumToVisibilityConverter},
                             ConverterParameter=Recording}">
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                <Grid IsEnabled="{Binding CanAddEntry}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="TimelineListBox" 
                             SelectionChanged="TimelineListBox_SelectionChanged"
                             ItemsSource="{Binding TimelineView}" 
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             SelectionMode="Extended"
                             Margin="2" Background="Transparent" BorderThickness="0">

                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="これ以降のケース番号を振り直す" 
                                          Click="RenumberCases_Click" />
                                <Separator />
                                <MenuItem Header="この項目を削除" Click="DeleteEntry_Click" />
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border x:Name="GroupBorder" Background="#EEE" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5,2"
                                                PreviewMouseLeftButtonDown="GroupHeader_PreviewMouseLeftButtonDown">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="IconTxt" Text="📋 " />
                                                <TextBlock x:Name="HeaderText" Text="{Binding Name, Converter={StaticResource GroupNameConverter}}"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:Bookmark}">
                                <StackPanel Orientation="Horizontal" Margin="5,2">
                                    <TextBlock x:Name="IconTxt" Text="●" Margin="0,0,5,0" Foreground="Gray" />
                                    <TextBlock Text="{Binding Time, StringFormat=\{0:mm\\:ss\}}" Width="45"/>
                                    <TextBlock Text="{Binding Result}" Width="40" Margin="5,0" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Result}" Value="OK">
                                                        <Setter Property="Foreground" Value="ForestGreen"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}" Value="NG">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result}" Value="PEND">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                        <Setter Property="Text" Value="SS"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text=" - " />
                                    <TextBlock Text="{Binding Note}" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                </StackPanel>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="RedBlink">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <ColorAnimation 
                                    Storyboard.TargetName="IconTxt" 
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    From="Red" To="Transparent" 
                                    Duration="0:0:0.5" 
                                    AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="RedBlink"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="#CCC"/>

                    <Grid Grid.Row="2" Margin="5">
                        <StackPanel Grid.Row="1" Margin="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="No" FontWeight="Bold" Margin="5,5,10,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" 
                                         TextChanged="CaesNoEditBox_TextChanged"
                                         Name="CaesNoEditBox"
                                         Text="{Binding SelectedItem.CaseId, UpdateSourceTrigger=PropertyChanged}" 
                                         VerticalAlignment="Center"
                                         Visibility="{Binding CurrentMode,
                                                      Converter={StaticResource EnumToVisibilityConverter},
                                                      ConverterParameter=Edit}"
                                         Height="20"/>

                                <TextBox Grid.Column="1" 
                                         Name="NextNoEditBox" 
                                         Text="{Binding NextNo, UpdateSourceTrigger=PropertyChanged}" 
                                         VerticalAlignment="Center"
                                         Visibility="{Binding CurrentMode,
                                                      Converter={StaticResource EnumToVisibilityConverter},
                                                      ConverterParameter=Recording}"
                                         Height="20"/>
                            </Grid>
                            <UniformGrid Columns="4" Margin="0,0,0,5">
                                <Button Command="{Binding ExecuteResultCommand}" CommandParameter="OK" 
                                        Content="OK" Background="ForestGreen" Foreground="White" Height="30" Margin="2"/>
                                <Button Command="{Binding ExecuteResultCommand}" CommandParameter="NG" 
                                        Content="NG" Background="Crimson" Foreground="White" Height="30" Margin="2"/>
                                <Button Command="{Binding ExecuteResultCommand}" CommandParameter="PEND" 
                                        Content="PEND" Background="Orange" Foreground="White" Height="30" Margin="2"/>
                                <Button Command="{Binding ExecuteResultCommand}" CommandParameter="SS" 
                                        Content="SS" Height="30" Margin="2"/>
                            </UniformGrid>

                            <TextBlock Text="コメント:" Margin="0,5,0,0"/>
                            <TextBox Name="NoteEditBox" Text="{Binding SelectedItem.Note, UpdateSourceTrigger=PropertyChanged}" 
             AcceptsReturn="True" 
             TextWrapping="Wrap" 
             Height="100" 
             VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- コントロールエリア -->
        <Border Grid.Row="2" Height="60" Background="LightGray" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel x:Name="RecordingTimerArea" 
                            Visibility="{Binding CurrentMode,
                                         Converter={StaticResource EnumToVisibilityConverter},
                                         ConverterParameter=Recording}">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="● REC" Foreground="Red" FontWeight="Bold" FontSize="20" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording, Source={x:Static service:RecService.Instance}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="BlinkStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="BlinkStoryboard"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>

                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock x:Name="BigRecordingTimerText" Grid.Column="1" 
                           Text="{Binding RecordingTime, Source={x:Static service:RecService.Instance}}"
                           FontFamily="Consolas" FontSize="40" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="PlayerControlsArea" VerticalAlignment="Center"
                            Visibility="{Binding CurrentMode,
                                         Converter={StaticResource EnumToVisibilityConverter},
                                         ConverterParameter=Edit}">

                    <Grid Margin="20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Canvas x:Name="ResultRangeCanvas" Grid.Row="0" Height="20" VerticalAlignment="Bottom"/>
                        <Slider x:Name="TimelineSlider" 
                                Grid.Row="1"
                                VerticalAlignment="Top"
                                IsMoveToPointEnabled ="True"
                                Minimum="0" 
                                Thumb.DragStarted="Slider_DragStarted" 
                                Thumb.DragCompleted="Slider_DragCompleted" 
                                ValueChanged="Slider_ValueChanged" 
                                PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                                PreviewMouseMove="Slider_PreviewMouseMove"
                                SizeChanged="TimelineSlider_SizeChanged">
                            <Slider.ToolTip>
                                <ToolTip x:Name="SliderToolTip">
                                    <TextBlock x:Name="ToolTipText" Text="00:00.000" FontWeight="Bold" />
                                </ToolTip>
                            </Slider.ToolTip>
                        </Slider>
                        <Canvas x:Name="BookmarkCanvas" Grid.Row="2" Height="10" Background="Transparent" />
                        <TextBlock x:Name="TimeText" Grid.Row="2" Text="00:00 / 00:00" HorizontalAlignment="Left" FontSize="11" Margin="0,2,0,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Vertical">
                <!-- 録画パネル -->
                <StackPanel x:Name="RecordingPanel" Orientation="Horizontal"
                            Visibility="{Binding CurrentMode, 
                                         Converter={StaticResource EnumToVisibilityConverter}, 
                                         ConverterParameter=Recording}">
                    <StackPanel x:Name="RegionPanel" Orientation="Horizontal">
                        <TextBlock Text="録画範囲：" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="ModeComboBox" SelectedIndex="0" Width="80" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="画面全体"/>
                            <ComboBoxItem Content="矩形選択"/>
                            <ComboBoxItem Content="ウインドウ"/>
                        </ComboBox>
                        <Button x:Name="SelectRegionButton" Content="範囲選択" Click="SelectRegionButton_Click" Padding="10,5"/>
                    </StackPanel>
                    <Button x:Name="RecordingButton" Click="RecordingButton_Click" Padding="15,5" Margin="10,0,10,0" Width="100">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="RecordingIcon" Text="🔴" Margin="0,0,5,0" Foreground="Red"/>
                            <TextBlock x:Name="RecordingText" Text="録画開始"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 再生パネル -->
                <StackPanel x:Name="PlayerPanel" Orientation="Horizontal"
                            Visibility="{Binding CurrentMode, 
                                         Converter={StaticResource EnumToVisibilityConverter}, 
                                         ConverterParameter=Edit}">
                    <StackPanel x:Name="PlaySpeedPanel" Orientation="Horizontal">
                        <TextBlock Text="速度:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="SpeedComboBox" Width="60" SelectedIndex="3" 
              SelectionChanged="SpeedComboBox_SelectionChanged" 
              VerticalContentAlignment="Center">
                            <ComboBoxItem Content="0.5x" Tag="0.5"/>
                            <ComboBoxItem Content="0.75x" Tag="0.75"/>
                            <ComboBoxItem Content="0.9x" Tag="0.9"/>
                            <ComboBoxItem Content="1.0x" Tag="1.0"/>
                            <ComboBoxItem Content="1.25x" Tag="1.25"/>
                            <ComboBoxItem Content="1.5x" Tag="1.5"/>
                            <ComboBoxItem Content="2.0x" Tag="2.0"/>
                        </ComboBox>
                    </StackPanel>
                    <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Padding="15,5" Margin="0,0,5,0" Width="100">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="PlayPauseIcon" Text="▶️" Margin="0,0,5,0"/>
                            <TextBlock x:Name="PlayPauseText" Text="再生"/>
                        </StackPanel>
                    </Button>
                    <CheckBox x:Name="StopAtPointCheckBox" Content="ポイント停止" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Orientation="Horizontal" 
                        DataContext="{Binding Evidence, Source={x:Static service:RecService.Instance}}">
                        <CheckBox x:Name="CropEnabledCheckBox" 
                              Checked="CropEnabledCheckBox_Changed"
                              Unchecked="CropEnabledCheckBox_Changed"
                              Content="グローバルフォーカス" 
                              IsChecked="{Binding IsCropEnabled}"
                              VerticalAlignment="Center" 
                              Margin="10,0,5,0"/>

                        <Button x:Name="CropButton" Click="OnConfirmCrop_Click" 
                            IsEnabled="{Binding IsChecked, ElementName=CropEnabledCheckBox}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#F0F0F0"/>
                                    <Setter Property="Content" Value="範囲変更"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CropState}" Value="Editing">
                                            <Setter Property="Background" Value="Orange"/>
                                            <Setter Property="Content" Value="範囲確定"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <StatusBar Grid.Row="4" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0">

            <StatusBarItem Margin="5,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="録画" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ModeToggleButton}" Value="False">
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ToggleButton x:Name="ModeToggleButton" 
                                  Cursor="Hand"
                                  IsChecked="{Binding IsEditMode, Mode=TwoWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource StandardToggleSwitchStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording, Source={x:Static service:RecService.Instance}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="ToolTip" Value="録画中はモードを切り替えられません" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <TextBlock Text="再生" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ModeToggleButton}" Value="True">
                                        <Setter Property="Foreground" Value="#4CD964"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📁 保存先: " Foreground="#555"/>
                    <TextBlock x:Name="SavePathStatusText" 
                   Text="未設定" 
                   MaxWidth="350" 
                   TextTrimming="CharacterEllipsis"
                   Foreground="Blue" 
                   Cursor="Hand"
                   PreviewMouseLeftButtonDown="SavePathStatusText_PreviewMouseLeftButtonDown">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.ToolTip>クリックしてフォルダを開く</TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FrameRateText" Text="FPS: --"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{Binding StatusText}" Foreground="Red" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>