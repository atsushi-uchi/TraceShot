<Window x:Class="TraceShot.Features.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TraceShot"
        xmlns:service="clr-namespace:TraceShot.Services"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="TraceShot" Height="600" Width="900">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarInfo" />
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <Style x:Key="StandardToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Rectangle x:Name="Back" RadiusX="10" RadiusY="10" Fill="#999999" Stroke="#BCBCBC" StrokeThickness="1"/>

                            <Ellipse x:Name="Dot" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="2">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.2"/>
                                </Ellipse.Effect>
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="Trans" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="開く(_O)..." Click="OpenEvidence_Click"/>
                <MenuItem Header="保存(_S)" Click="SaveEvidence_Click" InputGestureText="Ctrl+S"/>
                <MenuItem Header="エクスポート(_E)..." Click="OpenExport_Click"/>
                <Separator />
                <MenuItem Header="終了(_X)" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="設定(_P)" Click="OpenSettings_Click" />
            <!--<MenuItem x:Name="DebugMenuItem" Header="デバッグ ON" IsCheckable="True" Click="DebugButton_Click" />-->
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Black">
                <MediaElement x:Name="VideoPlayer" 
                      Stretch="Uniform"
                      LoadedBehavior="Manual" 
                      UnloadedBehavior="Stop" 
                      ScrubbingEnabled="True"
                      MediaOpened="VideoPlayer_MediaOpened"
                      MediaFailed="VideoPlayer_MediaFailed"
                      MediaEnded="VideoPlayer_MediaEnded"    
                      SizeChanged="DrawingCanvas_SizeChanged" >
                    <MediaElement.Style>
                        <Style TargetType="MediaElement">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </MediaElement.Style>
                </MediaElement>
                <Canvas x:Name="DrawingCanvas" Background="#01FFFFFF" 
                        MouseDown="DrawingCanvas_MouseDown"
                        MouseMove="DrawingCanvas_MouseMove"
                        MouseUp="DrawingCanvas_MouseUp" 
                        SizeChanged="DrawingCanvas_SizeChanged">
                    <!-- バルーンノート用 -->

                    <Border x:Name="BalloonInputComposite" 
        Visibility="Collapsed" 
        Width="220"
        Panel.ZIndex="1000"
        BorderBrush="#FF4A90E2" 
        BorderThickness="2"
        CornerRadius="5"
        Background="#F9FFFFFF">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" 
                          ShadowDepth="2" 
                          Opacity="0.35" 
                          Color="#000000"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="BalloonTextInput" 
                                     PreviewKeyDown="BalloonTextInput_PreviewKeyDown"
                                     LostFocus="BalloonTextInput_LostFocus"
                 AcceptsReturn="True" 
                 TextWrapping="Wrap" 
                 FontSize="14" 
                 FontWeight="SemiBold"
                 BorderThickness="0" 
                 Background="Transparent" 
                 Padding="8" 
                 MinHeight="50"
                 VerticalContentAlignment="Top"/>

                            <Border Grid.Column="1" 
                Background="#F0F5FB" 
                BorderBrush="#CCE0FF" 
                BorderThickness="1,0,0,0"
                CornerRadius="0,5,5,0">
                                <Button x:Name="BalloonMicButton" Focusable="False"
                    Width="32"
                    Background="Transparent" 
                    BorderThickness="0" 
                    VerticalAlignment="Stretch"
                    Click="BalloonMicButton_Click"
                    ToolTip="音声入力開始">
                                    <iconPacks:PackIconLucide x:Name="BalloonMicIcon" 
                                           Kind="Mic" 
                                           Width="18" Height="18" 
                                           Foreground="#FF4A90E2"/>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- バルーンノート用 -->
                </Canvas>

                <Grid x:Name="RecordingOverlay">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="BookmarkListBox" Grid.Row="0" Margin="2" SelectionChanged="BookmarkListBox_SelectionChanged"
                             SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,2">
                                    <TextBlock x:Name="IconTxt" Text="{Binding Icon}" Foreground="Black" />
                                    <TextBlock Text=" " />
                                    <TextBlock Text="{Binding Time, StringFormat=\{0:mm\\:ss\}}" />
                                    <TextBlock Text=" - " />
                                    <TextBlock Text="{Binding Note}" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsListening}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="RedBlink">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <ColorAnimation 
                        Storyboard.TargetName="IconTxt" 
                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                        From="Red" To="Transparent" 
                        Duration="0:0:0.5" 
                        AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="RedBlink"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="#CCC"/>

                    <Grid Grid.Row="2" Margin="10">
                        <TextBlock Text="コメント:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="NoteEditBox" Margin="0,22,0,0" TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding SelectedItem.Note, ElementName=BookmarkListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- コントロールエリア -->
        <Border Grid.Row="2" Height="60" Background="LightGray" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel x:Name="RecordingTimerArea">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="● REC" Foreground="Red" FontWeight="Bold" FontSize="20" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording, Source={x:Static service:RecService.Instance}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="BlinkStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="BlinkStoryboard"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>

                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock x:Name="BigRecordingTimerText" Grid.Column="1" 
                           Text="{Binding RecordingTime, Source={x:Static service:RecService.Instance}}"
                           FontFamily="Consolas" FontSize="40" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="PlayerControlsArea" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock x:Name="TimeText" Text="00:00 / 00:00" HorizontalAlignment="Right" FontSize="11" Margin="0,0,20,2"/>

                    <Slider x:Name="TimelineSlider" Margin="20,0"
                            IsMoveToPointEnabled ="True"
                            Minimum="0" 
                            Maximum="{Binding VideoDurationTotalSeconds}" 
                            Thumb.DragStarted="Slider_DragStarted" 
                            Thumb.DragCompleted="Slider_DragCompleted" 
                            ValueChanged="Slider_ValueChanged" 
                            PreviewMouseLeftButtonUp="Slider_PreviewMouseLeftButtonUp"
                            PreviewMouseMove="Slider_PreviewMouseMove">
                        <Slider.ToolTip>
                            <ToolTip x:Name="SliderToolTip">
                                <TextBlock x:Name="ToolTipText" Text="00:00.000" FontWeight="Bold" />
                            </ToolTip>
                        </Slider.ToolTip>
                    </Slider>
                    <Canvas x:Name="BookmarkCanvas" Height="10" Margin="10,-2,10,0" Background="Transparent" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="3" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <!-- 録画パネル -->
                <StackPanel x:Name="RecordingPanel" Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel x:Name="RegionPanel" Orientation="Horizontal">
                        <TextBlock Text="録画範囲：" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="ModeComboBox" SelectedIndex="0" Width="80" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="画面全体"/>
                            <ComboBoxItem Content="矩形選択"/>
                            <ComboBoxItem Content="ウインドウ"/>
                        </ComboBox>
                        <Button x:Name="SelectRegionButton" Content="範囲選択" Click="SelectRegionButton_Click" Padding="10,5"/>
                    </StackPanel>
                    <Button x:Name="RecordingButton" Click="RecordingButton_Click" Padding="15,5" Margin="10,0,10,0" Width="100">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="RecordingIcon" Kind="Dot"  Width="14" Height="14" Margin="0,2,5,0" Foreground="Red" />
                            <TextBlock x:Name="RecordingText" Text="録画開始"/>
                        </StackPanel>
                    </Button>
                    <Button Click="AddBookmarkWhileRecording_Click" Padding="10,5" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="RecordingEvidenceIcon" Kind="Camera" Width="14" Height="14" Margin="0,2,5,0" />
                            <TextBlock x:Name="RecordingEvidenceText" Text="証跡追加"/>
                        </StackPanel>
                    </Button>
                    <Button Click="AddVoiceMemoRecording_Click" Padding="10,5" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="RecordingVoiceIcon" Kind="Mic"  Width="14" Height="14" Margin="0,2,5,0" />
                            <TextBlock x:Name="RecordingVoiceText" Text="音声メモ"/>
                        </StackPanel>
                    </Button>
                    <CheckBox x:Name="ClickTriggerCheckBox" Content="クリック自動録画" IsChecked="False" VerticalAlignment="Center" Margin="5,0,10,0"
                              Checked="ClickTriggerCheckBox_Checked" Unchecked="ClickTriggerCheckBox_Unchecked"/>
                </StackPanel>

                <!-- 再生パネル -->
                <StackPanel x:Name="PlayerPanel" Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlayerMode}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel x:Name="PlaySpeedPanel" Orientation="Horizontal">
                        <TextBlock Text="速度:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="SpeedComboBox" Width="60" SelectedIndex="3" 
              SelectionChanged="SpeedComboBox_SelectionChanged" 
              VerticalContentAlignment="Center">
                            <ComboBoxItem Content="0.5x" Tag="0.5"/>
                            <ComboBoxItem Content="0.75x" Tag="0.75"/>
                            <ComboBoxItem Content="0.9x" Tag="0.9"/>
                            <ComboBoxItem Content="1.0x" Tag="1.0"/>
                            <ComboBoxItem Content="1.25x" Tag="1.25"/>
                            <ComboBoxItem Content="1.5x" Tag="1.5"/>
                            <ComboBoxItem Content="2.0x" Tag="2.0"/>
                        </ComboBox>
                    </StackPanel>
                    <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click" Padding="15,5" Margin="0,0,5,0" Width="100">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="PlayPauseIcon" Kind="Play" Width="14" Height="14" Margin="0,2,5,0" />
                            <TextBlock x:Name="PlayPauseText" Text="再生"/>
                        </StackPanel>
                    </Button>
                    <CheckBox x:Name="StopAtBookmarkCheckBox" Content="ポイント停止" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Click="AddBookmarkWhilePlaying_Click" Padding="10,5" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="PlayingEvidenceIcon" Kind="Camera" Width="14" Height="14" Margin="0,2,5,0" />
                            <TextBlock x:Name="PlayingEvidenceText" Text="証跡追加"/>
                        </StackPanel>
                    </Button>
                    <Button Click="AddVoiceMemoWhilePlaying_Click" Padding="10,5" Margin="0,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide x:Name="PlayingVoiceIcon" Kind="Mic" Width="14" Height="14" Margin="0,2,5,0" />
                            <TextBlock x:Name="PlayingVoiceText" Text="音声メモ"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <StatusBar Grid.Row="4" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0">

            <StatusBarItem Margin="5,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="録画" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ModeToggleButton}" Value="False">
                                        <Setter Property="Foreground" Value="Red"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ToggleButton x:Name="ModeToggleButton" 
                                  Cursor="Hand"
                                  IsChecked="{Binding IsPlayerMode, Mode=TwoWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource StandardToggleSwitchStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording, Source={x:Static service:RecService.Instance}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="ToolTip" Value="録画中はモードを切り替えられません" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <TextBlock Text="再生" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, ElementName=ModeToggleButton}" Value="True">
                                        <Setter Property="Foreground" Value="#4CD964"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📁 保存先: " Foreground="#555"/>
                    <TextBlock x:Name="SavePathStatusText" 
                   Text="未設定" 
                   MaxWidth="350" 
                   TextTrimming="CharacterEllipsis"
                   Foreground="Blue" 
                   Cursor="Hand"
                   PreviewMouseLeftButtonDown="SavePathStatusText_PreviewMouseLeftButtonDown">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.ToolTip>クリックしてフォルダを開く</TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="FrameRateText" Text="FPS: --"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Foreground="Red" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>