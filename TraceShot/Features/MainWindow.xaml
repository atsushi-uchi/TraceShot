<Window x:Class="TraceShot.Features.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TraceShot"
        mc:Ignorable="d"
        Title="TraceShot" Height="500" Width="850">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskbarInfo" />
    </Window.TaskbarItemInfo>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2" Background="White">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="開く(_O)..." Click="OpenEvidence_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📁"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="保存(_S)" Click="SaveEvidence_Click" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <TextBlock Text="💾"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="エクスポート(_E)..." Click="OpenExport_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="📊"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="終了(_X)" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="設定(_P)" Click="OpenSettings_Click" />
            <MenuItem Header="証跡クリア" Click="ClearBookmark_Click" />
            <MenuItem x:Name="DebugMenuItem" Header="デバッグ ON" IsCheckable="True" Click="DebugButton_Click" />
        </Menu>

        <Grid Grid.Row="1">
            <MediaElement x:Name="VideoPlayer" 
                          MediaOpened="VideoPlayer_MediaOpened"
                          MediaFailed="VideoPlayer_MediaFailed"
                          SizeChanged="DrawingCanvas_SizeChanged"
                          LoadedBehavior="Manual" 
                          UnloadedBehavior="Stop"
                          ScrubbingEnabled="True"
                          Visibility="Collapsed" 
                          Stretch="Uniform" />

            <Canvas x:Name="DrawingCanvas" Background="#01FFFFFF" 
                    SizeChanged="DrawingCanvas_SizeChanged"
                    MouseDown="DrawingCanvas_MouseDown"
                    MouseMove="DrawingCanvas_MouseMove"
                    MouseUp="DrawingCanvas_MouseUp" />
        </Grid>

        <Grid x:Name="RecordingOverlay" Grid.Row="1" Visibility="Collapsed" Background="Black">
            <Image x:Name="PreviewImage" Stretch="Uniform" />
        </Grid>

        <ListBox x:Name="BookmarkListBox" Grid.Column="1" Grid.Row="1" Margin="1" 
                 SelectionMode="Extended"
                 SelectionChanged="BookmarkListBox_SelectionChanged">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Margin="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,2,5,2">
                            <TextBlock x:Name="IconTxt" Text="{Binding Icon}" Foreground="Black" />
                            <TextBlock x:Name="SpaceTxt" Text=" " Foreground="Black" />
                            <TextBlock x:Name="TimeTxt" Text="{Binding Time, StringFormat=\{0:mm\\:ss\}}" Foreground="Black" />
                            <TextBlock x:Name="SepTxt" Text=" - " Foreground="Black" />
                            <TextBlock x:Name="NoteTxt" Text="{Binding Note}" Foreground="Black" />
                        </StackPanel>
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsListening}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard x:Name="RedBlink">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="IconTxt" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="Black" To="Red" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever" />
                                        <ColorAnimation Storyboard.TargetName="TimeTxt" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="Black" To="Red" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever" />
                                        <ColorAnimation Storyboard.TargetName="SepTxt" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="Black" To="Red" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever" />
                                        <ColorAnimation Storyboard.TargetName="NoteTxt" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="Black" To="Red" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="RedBlink" />
                            </DataTrigger.ExitActions>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsListening}" Value="False">
                            <Setter TargetName="IconTxt" Property="Foreground" Value="Black" />
                            <Setter TargetName="TimeTxt" Property="Foreground" Value="Black" />
                            <Setter TargetName="SepTxt" Property="Foreground" Value="Black" />
                            <Setter TargetName="NoteTxt" Property="Foreground" Value="Black" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>


        </ListBox>

        <Grid Grid.Column="1" Grid.Row="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="コメント:" Margin="5,0,0,2"/>

            <TextBox x:Name="NoteEditBox" 
                     Grid.Row="1"
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalContentAlignment="Top"
                     VerticalAlignment="Stretch"
                     Text="{Binding SelectedItem.Note, ElementName=BookmarkListBox, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />                     
        </Grid>

        <Border Grid.Row="2" Background="#F0F0F0" Padding="10" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <StackPanel>
                <Grid Margin="0,5">
                    <StackPanel x:Name="PlaybackControlsArea" Visibility="Visible">
                        <TextBlock x:Name="TimeText" Text="00:00 / 00:00" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                        <Slider x:Name="TimelineSlider" Margin="10,0"
                                Minimum="0" 
                                Maximum="{Binding VideoDurationTotalSeconds}"
                                Value="{Binding CurrentPositionSeconds}"
                                Thumb.DragStarted="Slider_DragStarted" 
                                Thumb.DragCompleted="Slider_DragCompleted" 
                                ValueChanged="Slider_ValueChanged"
                                PreviewMouseMove="Slider_PreviewMouseMove">
                            <Slider.ToolTip>
                                <ToolTip x:Name="SliderToolTip">
                                    <TextBlock x:Name="ToolTipText" Text="00:00.000" FontWeight="Bold" />
                                </ToolTip>
                            </Slider.ToolTip>
                        </Slider>

                        <Canvas x:Name="BookmarkCanvas" 
                                SizeChanged="BookmarkCanvas_SizeChanged"
                                Height="15"
                                Margin="7,-5,7,0"
                                VerticalAlignment="Top" 
                                Background="Transparent" 
                                />
                    </StackPanel>

                    <Grid x:Name="RecordingTimerArea" Visibility="Collapsed" Height="60" Background="#E0E0E0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="● REC" Foreground="Red" FontWeight="Bold" FontSize="18" Margin="0,0,15,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock x:Name="BigRecordingTimerText" Text="00:00:00" FontFamily="Consolas" FontSize="36" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="StartStopButton" Width="100" Click="StartStopButton_Click" Margin="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="StartStopIcon" Text="●" Foreground="Red" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StartStopText" Text="録画開始" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PlayPauseButton" Width="100" Click="PlayPauseButton_Click" Margin="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="PlayPauseIcon" Text="▶" Margin="0,0,5,0"/>
                            <TextBlock x:Name="PlayPauseText" Text="再生"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="AddBookmarkButton" Content="📌 証跡追加" Click="AddBookmarkButton_Click" Width="100" Height="40" Margin="5"/>
                    <!--<Button x:Name="DeleteBookmarkButton" Content="🗑️ 証跡削除" Click="DeleteBookmarkButton_Click" Width="100" Margin="5" />-->
                    <Button x:Name="VoiceMemoButton" Content="🎤 音声メモ" Click="VoiceMemoButton_Click" Width="100" Margin="5" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <TextBlock Text="録画範囲：" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ModeComboBox" Width="90" SelectedIndex="0" Height="30" Padding="5"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="画面全体"/>
                        <ComboBoxItem Content="矩形選択"/>
                        <ComboBoxItem Content="ウインドウ"/>
                    </ComboBox>
                    <Button x:Name="SelectRegionButton" Content="範囲選択" Click="SelectRegionButton_Click" Margin="5" Padding="5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="3" Grid.ColumnSpan="2" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📁 保存先: " Foreground="#555"/>
                    <TextBlock x:Name="SavePathStatusText" 
                   Text="未設定" 
                   MaxWidth="350" 
                   TextTrimming="CharacterEllipsis"
                   Foreground="Blue" 
                   Cursor="Hand"
                   PreviewMouseLeftButtonDown="SavePathStatusText_PreviewMouseLeftButtonDown">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextBlock.TextDecorations" Value="Underline" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.ToolTip>クリックしてフォルダを開く</TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🖥️ FPS: " Foreground="#555"/>
                    <TextBlock x:Name="FrameRateText" Text="--"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Foreground="Red" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>