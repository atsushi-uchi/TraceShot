<Window x:Class="TraceShot.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Coordinates" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        Topmost="True" 
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight">
    <Grid x:Name="DebugGrid">
        <Border x:Name="InfoPanel" 
                Background="#CC000000" 
                CornerRadius="5" 
                Padding="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TxtPhys" Foreground="White" FontSize="14" FontFamily="Consolas" Text="物理: ---"/>
                <TextBlock x:Name="TxtScreen" Foreground="Cyan" FontSize="14" FontFamily="Consolas" Text="画面: ---"/>
                <TextBlock x:Name="TxtWpf" Foreground="Yellow" FontSize="14" FontFamily="Consolas" Text="WPF: ---"/>
                <TextBlock x:Name="TxtDpi" Foreground="Lime" FontSize="14" FontFamily="Consolas" Text="DPI: ---"/>
                <TextBlock x:Name="TxtMon" Foreground="Red" FontSize="14" FontFamily="Consolas" Text="MON: ---"/>
                <TextBlock x:Name="TxtDev" Foreground="Fuchsia" FontSize="14" FontFamily="Consolas" Text="DEV: ---"/>

                <TextBlock Foreground="Gray" FontSize="10" Text="Debug Moniter" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>